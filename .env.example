# Supabase
# Copy this file to .env and fill in your Supabase keys.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public base URL used for generating QR codes in deployed environments.
# Example (Vercel): https://your-vercel-project.vercel.app
# Leave blank to default to window.location.origin (works for local dev).
VITE_PUBLIC_BASE_URL=

